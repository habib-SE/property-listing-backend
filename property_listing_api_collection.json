{
    "info": {
        "name": "Property Listing API",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:5000",
            "type": "string"
        },
        {
            "key": "token",
            "value": "your_jwt_token_here",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "Auth",
            "item": [
                {
                    "name": "Register",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"password123\",\n  \"private_or_agency\": \"private\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/auth/register",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "register"
                            ]
                        }
                    }
                },
                {
                    "name": "Login",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"password123\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/auth/login",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "login"
                            ]
                        }
                    }
                },
                {
                    "name": "Get Me",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/auth/me",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "auth",
                                "me"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Properties",
            "item": [
                {
                    "name": "List Properties",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/api/properties?city_id=1&property_status=for-sale",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "properties"
                            ],
                            "query": [
                                {
                                    "key": "city_id",
                                    "value": "1"
                                },
                                {
                                    "key": "property_status",
                                    "value": "for-sale"
                                }
                            ]
                        }
                    }
                },
                {
                    "name": "Get Property By ID",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/api/properties/1",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "properties",
                                "1"
                            ]
                        }
                    }
                },
                {
                    "name": "Create Property",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "body": {
                            "mode": "formdata",
                            "formdata": [
                                {
                                    "key": "address",
                                    "value": "123 Main St",
                                    "type": "text"
                                },
                                {
                                    "key": "city_id",
                                    "value": "1",
                                    "type": "text"
                                },
                                {
                                    "key": "price",
                                    "value": "500000",
                                    "type": "text"
                                },
                                {
                                    "key": "property_status",
                                    "value": "for-sale",
                                    "type": "text"
                                },
                                {
                                    "key": "bedrooms",
                                    "value": "3",
                                    "type": "text"
                                },
                                {
                                    "key": "bathrooms",
                                    "value": "2",
                                    "type": "text"
                                },
                                {
                                    "key": "images",
                                    "type": "file",
                                    "src": []
                                }
                            ]
                        },
                        "url": {
                            "raw": "{{base_url}}/api/properties",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "properties"
                            ]
                        }
                    }
                },
                {
                    "name": "Update Property",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"price\": \"550000\",\n  \"property_status\": \"sold\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/properties/1",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "properties",
                                "1"
                            ]
                        }
                    }
                },
                {
                    "name": "Delete Property",
                    "request": {
                        "method": "DELETE",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/properties/1",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "properties",
                                "1"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Locations",
            "item": [
                {
                    "name": "Get Cities",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/api/locations/cities",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "locations",
                                "cities"
                            ]
                        }
                    }
                },
                {
                    "name": "Get Developers",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/api/locations/developers",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "locations",
                                "developers"
                            ]
                        }
                    }
                },
                {
                    "name": "Get Communities",
                    "request": {
                        "method": "GET",
                        "header": [],
                        "url": {
                            "raw": "{{base_url}}/api/locations/communities?city_id=1",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "locations",
                                "communities"
                            ],
                            "query": [
                                {
                                    "key": "city_id",
                                    "value": "1"
                                }
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Inquiries",
            "item": [
                {
                    "name": "Submit Inquiry",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"property_id\": 1,\n  \"full_name\": \"Jane Doe\",\n  \"email\": \"jane@example.com\",\n  \"phone\": \"1234567890\",\n  \"message\": \"I am interested in this property!\",\n  \"inquiry_type\": \"general\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/inquiries",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "inquiries"
                            ]
                        }
                    }
                },
                {
                    "name": "Get Inquiries (Auth)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/inquiries",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "inquiries"
                            ]
                        }
                    }
                }
            ]
        }
    ]
}